; Engine configuration file.
; It's best edited using the editor UI and not directly,
; since the parameters that go here are not all obvious.
;
; Format:
;   [section] ; section goes between []
;   param=value ; assign values to parameters

config_version=5

[application]

config/name="Dungeon Oratoria"
config/version="0.7.1"
run/main_scene="res://scenes/ui/main_menu.tscn"
; Carpeta de guardado FIJA (user://), desacoplada del nombre visible: asi cambiar config/name
; NO mueve las partidas nunca mas. En Windows resuelve a %APPDATA%\DungeonOratoria\.
config/use_custom_user_dir=true
config/custom_user_dir_name="DungeonOratoria"
config/features=PackedStringArray("4.7", "GL Compatibility")
config/icon="res://icon.svg"

[autoload]

Perfil="*res://scripts/core/profile.gd"
Game="*res://scripts/core/game.gd"

[debug]

file_logging/enable_file_logging=true
file_logging/max_log_files=20

[display]

window/stretch/mode="canvas_items"
window/stretch/aspect="expand"

[input]

